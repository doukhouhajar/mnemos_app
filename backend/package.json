{
  "name": "mnemos-backend",
  "version": "0.1.0",
  "description": "MNEMOS backend services",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "node dist/db/migrate.js",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "psql $DB_NAME -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && psql $DB_NAME < src/db/schema.sql && npm run db:seed"
  },
  "keywords": ["memory", "spaced-repetition", "learning"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "openai": "^4.20.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  }
}

